<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ============================================================ -->
    <!-- Propiedades compartidas                                       -->
    <!-- ============================================================ -->
    <springProperty scope="context" name="LOG_LEVEL"    source="logging.level.com.integrityfamily" defaultValue="DEBUG"/>
    <springProperty scope="context" name="LOG_FILE"     source="logging.file.name"                  defaultValue="/app/logs/backend.log"/>

    <!-- Patrón de logs -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}  %-5level %d{yyyy-MM-dd}T%d{HH:mm:ss.SSSZ} --- [%15.15t] %-40.40logger{39} : %msg%n"/>

    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z', UTC}  %-5level 1 --- [%15.15t] %-50.50logger{49} : %msg%n"/>

    <!-- ============================================================ -->
    <!-- Appender: Consola con UTF-8 explícito                        -->
    <!-- ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- Charset UTF-8 explícito — necesario en Alpine (locale POSIX/C) -->
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- Appender: Archivo con rolling policy y UTF-8                 -->
    <!-- ============================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- Loggers específicos — reducen el ruido en scheduling-1       -->
    <!-- ============================================================ -->
    <logger name="com.integrityfamily"                level="${LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- SQL Hibernate: solo DEBUG cuando LOG_LEVEL=DEBUG -->
    <logger name="org.hibernate.SQL"                  level="${LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Reduce verbosidad del scheduler watchdog a INFO en producción -->
    <logger name="com.integrityfamily.analytics.service.SecurityWatchdogService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Spring Framework: INFO por defecto -->
    <logger name="org.springframework"               level="INFO"/>
    <logger name="com.zaxxer.hikari"                 level="INFO"/>
    <logger name="org.flywaydb"                      level="INFO"/>

    <!-- Root -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
